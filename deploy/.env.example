# ============================================
# PaperSpark 环境配置
# ============================================
#
# 复制此文件为 .env 并填写实际值：
#   cp .env.example .env
#
# ============================================

# --------------------------------------------
# 镜像配置（可选，默认使用 Docker Hub 官方镜像）
# --------------------------------------------
# DOCKER_REGISTRY=docker.io
# DOCKER_USER=paperspark
# VERSION=latest           # ARM64 可选 latest-arm64
# SURYA_VERSION=cpu        # ARM64 可选 cpu-arm64，GPU 可选 gpu-cu126
# SURYA_GPU_VERSION=gpu-cu126

# --------------------------------------------
# AI 模型配置 - 小模型（快速响应，推荐免费模型）
# --------------------------------------------
NEXT_PUBLIC_SMALL_MODEL_BASE_URL=https://openrouter.ai/api/v1
NEXT_PUBLIC_SMALL_MODEL_API_KEY=your_api_key_here
NEXT_PUBLIC_SMALL_MODEL_NAME=stepfun/step-3.5-flash:free

# --------------------------------------------
# AI 模型配置 - 大模型（高质量输出）
# --------------------------------------------
NEXT_PUBLIC_LARGE_MODEL_BASE_URL=https://api.openai.com/v1
NEXT_PUBLIC_LARGE_MODEL_API_KEY=your_api_key_here
NEXT_PUBLIC_LARGE_MODEL_NAME=gpt-4o

# --------------------------------------------
# 嵌入模型配置（RAG 向量检索）
# --------------------------------------------
NEXT_PUBLIC_EMBEDDING_BASE_URL=https://api.openai.com/v1/embeddings
NEXT_PUBLIC_EMBEDDING_API_KEY=your_api_key_here
NEXT_PUBLIC_EMBEDDING_NAME=text-embedding-3-small

# --------------------------------------------
# OCR 服务配置
# --------------------------------------------
SURYA_MAX_WORKERS=2
