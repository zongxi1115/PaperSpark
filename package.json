{
  "name": "paper_reader",
  "private": true,
  "type": "module",
  "description": "PaperSpark desktop workspace for AI-assisted paper reading and academic writing.",
  "author": "PaperSpark",
  "main": "electron/main.mjs",
  "version": "1.1.1",
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "data:cli": "node scripts/paperspark-data-cli.mjs",
    "desktop:dev": "node scripts/dev-electron.mjs",
    "desktop:build": "node scripts/prepare-electron-bundle.mjs",
    "desktop:pack": "pnpm build && pnpm desktop:build && electron-builder --dir",
    "desktop:dist": "pnpm build && pnpm desktop:build && electron-builder"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/jszip": "^3.4.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "semantic-release": "^25.0.3",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@antv/x6": "^2.19.2",
    "@antv/x6-plugin-clipboard": "^2.1.6",
    "@antv/x6-plugin-export": "^2.1.6",
    "@antv/x6-plugin-history": "^2.2.4",
    "@antv/x6-plugin-keyboard": "^2.2.3",
    "@antv/x6-plugin-selection": "^2.2.2",
    "@antv/x6-plugin-snapline": "^2.1.7",
    "@antv/x6-plugin-stencil": "^2.1.5",
    "@antv/x6-react-shape": "^2.2.3",
    "@blocknote/core": "^0.47.1",
    "@blocknote/mantine": "^0.47.1",
    "@blocknote/react": "^0.47.1",
    "@blocknote/xl-ai": "^0.47.1",
    "@heroui/react": "^2.8.10",
    "@iconify/react": "^6.0.2",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@xyflow/react": "^12.10.1",
    "ai": "^6.0.116",
    "chromadb": "^3.3.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dexie": "^4.3.0",
    "framer-motion": "^12.35.2",
    "jszip": "^3.10.1",
    "lucide-react": "^1.7.0",
    "marked": "^17.0.6",
    "mathlive": "^0.108.3",
    "mermaid": "^11.13.0",
    "motion": "^12.38.0",
    "next": "^15.3.0",
    "openai": "^6.27.0",
    "pdfjs-dist": "^5.5.207",
    "prosemirror-state": "^1.4.4",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.3",
    "zod": "^4.3.6"
  },
  "build": {
    "appId": "com.paperspark.desktop",
    "productName": "PaperSpark",
    "asar": true,
    "asarUnpack": [
      ".next/standalone/**/*",
      "scripts/start_surya_service.py",
      "services/surya_ocr_service/**/*"
    ],
    "directories": {
      "output": "release/electron",
      "buildResources": "desktop-resources"
    },
    "files": [
      "electron/**/*",
      ".next/standalone/**/*",
      "scripts/start_surya_service.py",
      "services/surya_ocr_service/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "desktop-resources",
        "to": "desktop-resources",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "PaperSpark-${version}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "PaperSpark-${version}-mac-${arch}.${ext}"
    }
  }
}
