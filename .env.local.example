# ============================================
# PaperSpark 本地开发环境变量示例
# ============================================
#
# 用法：
# 1. 复制为 .env.local
# 2. 按需填写 API Key / 服务地址
# 3. 重启 `pnpm dev`
#
# Modal 云部署场景：
# 将下面 4 个 SURYA 地址都改成你的 Modal Web Endpoint
# 本地微服务场景：
# 保持为 http://127.0.0.1:8765 即可
# ============================================

# --------------------------------------------
# AI 模型配置 - 小模型（快速响应，不写也可以，进页面调整也行，下同）
# --------------------------------------------
NEXT_PUBLIC_SMALL_MODEL_BASE_URL=https://openrouter.ai/api/v1
NEXT_PUBLIC_SMALL_MODEL_API_KEY=your_small_model_api_key
NEXT_PUBLIC_SMALL_MODEL_NAME=stepfun/step-3.5-flash:free

# --------------------------------------------
# AI 模型配置 - 大模型（高质量输出）
# --------------------------------------------
NEXT_PUBLIC_LARGE_MODEL_BASE_URL=https://api.openai.com/v1
NEXT_PUBLIC_LARGE_MODEL_API_KEY=your_large_model_api_key
NEXT_PUBLIC_LARGE_MODEL_NAME=gpt-4o

# --------------------------------------------
# 嵌入模型配置（RAG）
# --------------------------------------------
NEXT_PUBLIC_EMBEDDING_BASE_URL=https://api.openai.com/v1/embeddings
NEXT_PUBLIC_EMBEDDING_API_KEY=your_embedding_api_key
NEXT_PUBLIC_EMBEDDING_NAME=text-embedding-3-small

# --------------------------------------------
# 重排序模型配置（可选）
# --------------------------------------------
NEXT_PUBLIC_RERANK_MODEL_BASE_URL=https://api.openai.com/v1/rerank
NEXT_PUBLIC_RERANK_MODEL_API_KEY=your_rerank_api_key
NEXT_PUBLIC_RERANK_MODEL_NAME=text-rerank-3-small

# --------------------------------------------
# 服务端兼容回退配置（可选）
# 某些服务端链路会读取这些变量作为默认值
# --------------------------------------------
BASE_URL=https://api.openai.com/v1
API_KEY=your_server_side_api_key
EMBEDDING_NAME=text-embedding-3-small
RERANK_BASE_URL=https://api.openai.com/v1/rerank
RERANKER_NAME=text-rerank-3-small

# --------------------------------------------
# Surya OCR 服务地址
# 本地微服务默认值： http://127.0.0.1:8765
# Modal 部署时改为你的 modal.run 地址
# --------------------------------------------
SURYA_OCR_SERVICE_URL=http://127.0.0.1:8765
SURYA_SERVICE_URL=http://127.0.0.1:8765
NEXT_PUBLIC_SURYA_SERVICE_URL=http://127.0.0.1:8765
NEXT_PUBLIC_SURYA_OCR_SERVICE_URL=http://127.0.0.1:8765

# --------------------------------------------
# 会话配置（可选）
# --------------------------------------------
AUTH_SESSION_SECRET=change-this-in-production
AUTH_SESSION_TTL=604800



# --------------------------------------------
# OpenAlex（可选）
# --------------------------------------------
OPENALEX_API_KEY=
OPENALEX_EMAIL=

# --------------------------------------------
# Zotero OAuth（可选）
# 不配置时仅无法使用 Zotero OAuth 流程
# --------------------------------------------
ZOTERO_CLIENT_KEY=
ZOTERO_CLIENT_SECRET=
